# 5. Meta-Analysis: rs8192675 (SLC2A2)

## 5.1 Calculations

### Fixed-Effects — Inverse-Variance Weighting

$$\hat{\beta}_{FE} = \frac{\sum_{i=1}^{S} w_i \hat{\beta}_i}{\sum_{i=1}^{S} w_i}, \quad w_i = \frac{1}{\sigma^2_{\hat{\beta}_i}}$$

```{r fe-manual}
# Prepare study-level vectors
betas <- c(study_metgen$Beta, sugar_slc2a2$Beta)
ses   <- c(study_metgen$SE, sugar_slc2a2$SE)
names <- c("MetGen (European)", "SUGAR-MGH (Multi-Ancestry)")

# Fixed-effects weights
w <- 1 / ses^2

cat("Study weights (w_i = 1/SE^2):\n")
for (i in seq_along(w)) {
  cat(sprintf("  %s: w = %.2f (%.1f%%)\n", names[i], w[i], 100 * w[i] / sum(w)))
}

# Pooled estimate
beta_FE <- sum(w * betas) / sum(w)
se_FE   <- 1 / sqrt(sum(w))
z_FE    <- beta_FE / se_FE
p_FE    <- 2 * pnorm(-abs(z_FE))

cat(sprintf("\nPooled Beta_FE = %.4f\n", beta_FE))
cat(sprintf("SE(Beta_FE)    = %.4f\n", se_FE))
cat(sprintf("Z-statistic    = %.4f\n", z_FE))
cat(sprintf("P-value        = %.2e\n", p_FE))
cat(sprintf("95%% CI         = [%.4f, %.4f]\n",
            beta_FE - 1.96 * se_FE, beta_FE + 1.96 * se_FE))
```

### Cochran's Q — Test for Heterogeneity

$$Q = \sum_{i=1}^{S} \frac{(\hat{\beta}_i - \hat{\beta}_{FE})^2}{\sigma^2_{\hat{\beta}_i}} \sim \chi^2_{S-1}$$

```{r cochran-q}
Q     <- sum(w * (betas - beta_FE)^2)
Q_df  <- length(betas) - 1
Q_p   <- pchisq(Q, df = Q_df, lower.tail = FALSE)
I2    <- max(0, (Q - Q_df) / Q) * 100

cat(sprintf("Cochran's Q = %.4f (df = %d)\n", Q, Q_df))
cat(sprintf("P-value     = %.4e\n", Q_p))
cat(sprintf("I-squared   = %.1f%%\n", I2))
```

### Random-Effects — DerSimonian-Laird

$$\hat{\beta}_{RE} = \frac{\sum_{i=1}^{S} w^*_i \hat{\beta}_i}{\sum_{i=1}^{S} w^*_i}, \quad w^*_i = \frac{1}{\sigma^2_{\hat{\beta}_i} + \hat{\tau}^2}$$


```{r re-manual}
# Estimate between-study variance (tau^2) via DerSimonian-Laird
C_val <- sum(w) - sum(w^2) / sum(w)
tau2  <- max(0, (Q - Q_df) / C_val)

# Random-effects weights
w_star <- 1 / (ses^2 + tau2)

cat("Between-study variance:\n")
cat(sprintf("  tau^2 = %.6f\n", tau2))
cat(sprintf("  tau   = %.4f\n\n", sqrt(tau2)))

cat("Random-effects weights:\n")
for (i in seq_along(w_star)) {
  cat(sprintf("  %s: w* = %.2f (%.1f%%)\n",
              names[i], w_star[i], 100 * w_star[i] / sum(w_star)))
}

# Pooled RE estimate
beta_RE <- sum(w_star * betas) / sum(w_star)
se_RE   <- 1 / sqrt(sum(w_star))
z_RE    <- beta_RE / se_RE
p_RE    <- 2 * pnorm(-abs(z_RE))

cat(sprintf("\nPooled Beta_RE = %.4f\n", beta_RE))
cat(sprintf("SE(Beta_RE)    = %.4f\n", se_RE))
cat(sprintf("Z-statistic    = %.4f\n", z_RE))
cat(sprintf("P-value        = %.4e\n", p_RE))
cat(sprintf("95%% CI         = [%.4f, %.4f]\n",
            beta_RE - 1.96 * se_RE, beta_RE + 1.96 * se_RE))
```

## 5.2 Verification with `meta::metagen()`

```{r meta-package}
slc2a2_df <- data.frame(
  Study = names,
  Beta  = betas,
  SE    = ses
)

m_slc2a2 <- metagen(
  TE         = Beta,
  seTE       = SE,
  data       = slc2a2_df,
  studlab    = Study,
  sm         = "MD",
  common     = TRUE,
  random     = TRUE,
  method.tau = "DL",
  title      = "rs8192675 (SLC2A2) — HbA1c Response to Metformin"
)

summary(m_slc2a2)
```


