## 5.4 Forest Plot

```{r}
# ---- Data ----
forest_df <- data.frame(
  label  = c("MetGen (European)", "SUGAR-MGH (Multi-Ancestry)",
             "", "Common effect model", "Random effects model"),
  beta   = c(0.17, -0.03, NA, 0.14, 0.07),
  ci_lo  = c(0.13, -0.13, NA, 0.10, -0.13),
  ci_hi  = c(0.21,  0.06, NA, 0.18,  0.27),
  weight = c("52.3%", "47.7%", "", "\u2014", "100.0%"),
  group  = c("study", "study", "spacer", "pooled", "pooled"),
  y      = c(5, 4, 3, 2, 1)
)

forest_df$ci_text <- ifelse(
  is.na(forest_df$beta), "",
  sprintf("%.2f [%.2f, %.2f]", forest_df$beta, forest_df$ci_lo, forest_df$ci_hi)
)

studies <- forest_df[forest_df$group == "study", ]
pooled  <- forest_df[forest_df$group == "pooled", ]

# ---- Diamond polygons ----
make_diamond <- function(row) {
  data.frame(
    x  = c(row$ci_lo, row$beta, row$ci_hi, row$beta),
    y  = c(row$y, row$y + 0.22, row$y, row$y - 0.22),
    id = row$label
  )
}
diamonds <- do.call(rbind, lapply(seq_len(nrow(pooled)), function(i) make_diamond(pooled[i, ])))

# ---- Layout constants ----
# Widen the canvas: labels on left, plot in center, annotations on right
x_label   <- -0.42   # left edge for study labels
x_ci      <-  0.52   # right-side: Beta [95% CI] column
x_wt      <-  0.63   # right-side: Weight column
x_hdr_y   <-  6.2    # header row y position
x_min     <- -0.42
x_max     <-  0.67

# ---- Build plot ----
ggplot() +

  # Null effect line
  geom_vline(xintercept = 0, linetype = "dashed", color = "gray60", linewidth = 0.4) +

  # Separator line between studies and pooled
  geom_segment(aes(x = -0.22, xend = 0.32, y = 3, yend = 3),
               color = "gray80", linewidth = 0.3) +

  # ---- Study rows: CI lines + squares ----
  geom_segment(data = studies,
               aes(x = ci_lo, xend = ci_hi, y = y, yend = y),
               linewidth = 0.8, color = "gray30") +
  geom_point(data = studies,
             aes(x = beta, y = y),
             shape = 15, color = "steelblue",
             size = c(4.5, 3.8)) +  

  # ---- Pooled rows: diamonds ----
  geom_polygon(data = diamonds[diamonds$id == "Common effect model", ],
               aes(x = x, y = y),
               fill = "gray55", color = "gray40", linewidth = 0.5) +
  geom_polygon(data = diamonds[diamonds$id == "Random effects model", ],
               aes(x = x, y = y),
               fill = "#B22222", color = "#8B0000", linewidth = 0.5) +

  # ---- Left column: study labels ----
  # Header
  annotate("text", x = x_label, y = x_hdr_y, label = "Study",
           hjust = 0, size = 3.5, fontface = "bold") +

  # Study names — 
  annotate("text", x = x_label, y = 5, label = "MetGen (European)",
           hjust = 0, size = 3.2) +
  annotate("text", x = x_label, y = 4, label = "SUGAR-MGH (Multi-Ancestry)",
           hjust = 0, size = 3.2) +

  # Pooled labels
  annotate("text", x = x_label, y = 2, label = "Common effect model",
           hjust = 0, size = 3.2, fontface = "bold") +
  annotate("text", x = x_label, y = 1, label = "Random effects model",
