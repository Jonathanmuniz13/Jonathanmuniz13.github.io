# ── Load packages ──────────────────────────────────────────────────────────
# install.packages(c('tidyverse','skimr','broom','pROC','knitr','scales',
#                     'patchwork','ggcorrplot','car','kableExtra'))
library(tidyverse)
library(skimr)
library(broom)
library(pROC)
library(knitr)
library(scales)
library(patchwork)
library(forcats)
library(ggcorrplot)
library(car)
# ── Custom theme ───────────────────────────────────────────────────────────
theme_proj <- function(base_size = 12) {
theme_minimal(base_size = base_size) %+replace%
theme(
plot.title       = element_text(face = "bold", size = rel(1.15),
hjust = 0, margin = margin(b = 8)),
plot.subtitle    = element_text(color = "grey40", margin = margin(b = 10)),
panel.grid.minor = element_blank(),
panel.grid.major = element_line(color = "grey90"),
axis.title       = element_text(size = rel(0.9)),
strip.text       = element_text(face = "bold"),
legend.position  = "bottom"
)
}
# ── Colorblind-safe outcome palette ────────────────────────────────────────
# Consistent across all outcome-based plots.
# Muted blue = Survived, Deep coral = Died (intuitive severity mapping)
outcome_pal <- c("Survived" = "#4477AA", "Died" = "#CC3311")
or_tbl <- broom::tidy(logit_fit, exponentiate = TRUE, conf.int = TRUE) %>%
filter(term != "(Intercept)") %>%
mutate(term_label = case_match(term,
"age"                 ~ "Age (per year)",
"genderM"             ~ "Male gender",
"elective_surgeryYes" ~ "Elective surgery",
"log_pre_icu_los"     ~ "Pre-ICU LOS (log days)",
"d1_mbp_min"          ~ "Min mean BP (per mmHg)",
"d1_spo2_min"         ~ "Min SpO2 (per %)",
"d1_resprate_max"     ~ "Max resp rate (per br/min)",
"d1_creatinine_max"   ~ "Max creatinine (per mg/dL)",
"d1_bun_max"          ~ "Max BUN (per mg/dL)",
"d1_wbc_max"          ~ "Max WBC (per 10³/µL)",
.default              ~ term  # Safety fallback
))
